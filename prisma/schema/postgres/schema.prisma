generator client {
    provider        = "prisma-client-js"
    output          = "../generated/postgres/client"
    previewFeatures = ["relationJoins"]
}

generator zod {
    provider = "pnpm exec zod-prisma-types"
    output   = "../generated/postgres/zod"
}

datasource db {
    provider = "postgresql"
    url      = env("PG_DATABASE_URL")
}
